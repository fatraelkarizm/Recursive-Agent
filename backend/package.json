{
  "name": "backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "postinstall": "prisma generate --schema prisma/schema.prisma",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "tsx --test src/db/mission-store.test.ts src/public-runtime-diagnostics.test.ts",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@e2b/code-interpreter": "^1.5.0",
    "@langchain/core": "^0.3.43",
    "@langchain/langgraph": "^0.2.60",
    "@prisma/client": "^6.19.3",
    "@tavily/core": "^0.7.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "nanoid": "^5.1.5",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
