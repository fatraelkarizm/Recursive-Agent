OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
E2B_API_KEY=""
DATABASE_URL="postgresql://recursive:postgres@localhost:5432/recursive_agent?schema=public"
REDIS_URL=""

# Tavily (Extract for “browser” URL read + Search on research-style tool route)
TAVILY_API_KEY=""

# OpenClaw CLI bridge (mother → fleet orchestration). Set OPENCLAW_ORCHESTRATION=0 to disable.
OPENCLAW_ORCHESTRATION=""
OPENCLAW_BIN="openclaw"
OPENCLAW_ORCHESTRATOR_AGENT="main"
OPENCLAW_SESSION_PREFIX=""
OPENCLAW_USE_LOCAL="1"
OPENCLAW_TIMEOUT_MS="120000"
# Force this model for every OpenClaw call from this API (overrides agent default for that run).
# Example DeepSeek V4 Pro (OpenClaw ref: provider/model-id):
OPENCLAW_MODEL="deepseek/deepseek-v4-pro"
# API key for DeepSeek — loaded from backend/.env and passed to the `openclaw` child process.
DEEPSEEK_API_KEY=""

# Tavily web-read step (legacy env name). Set BROWSER_AUTOMATION=0 to skip URL extract.
BROWSER_AUTOMATION=""
BROWSER_DEFAULT_URL=""
