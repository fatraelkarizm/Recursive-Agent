OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
E2B_API_KEY=""
DATABASE_URL="postgresql://recursive:postgres@localhost:5432/recursive_agent?schema=public"
REDIS_URL=""

# Tavily (Extract for “browser” URL read + Search on research-style tool route)
TAVILY_API_KEY=""

# OpenClaw CLI bridge. Use 1 to allow CLI (fleet fallback per sub-agent). Set 0 to skip all OpenClaw calls.
OPENCLAW_ORCHESTRATION="1"
# Default on: every mission gets sub-agent fleet orchestration without typing "fleet"/"openclaw". Set to 0 for keyword-only orchestration.
AUTO_ORCHESTRATION="1"
OPENCLAW_BIN="openclaw"
OPENCLAW_ORCHESTRATOR_AGENT="main"
OPENCLAW_SESSION_PREFIX=""
OPENCLAW_USE_LOCAL="1"
OPENCLAW_TIMEOUT_MS="120000"
# Force this model for every OpenClaw call from this API (overrides agent default for that run).
# Example DeepSeek V4 Pro (OpenClaw ref: provider/model-id):
OPENCLAW_MODEL="qwen3.6-plus"
# API key for DeepSeek — loaded from backend/.env and passed to the `openclaw` child process.
DEEPSEEK_API_KEY=""

# Optional: OpenAI-compatible gateway (SumoPod, LiteLLM, etc.) — same curl shape as POST /v1/chat/completions.
# Base URL must include /v1 (e.g. https://ai.sumopod.com/v1). Bearer defaults to DEEPSEEK_API_KEY if OPENAI_COMPAT_API_KEY is empty.
OPENAI_COMPAT_BASE_URL=""
OPENAI_COMPAT_API_KEY=""
OPENAI_COMPAT_MODEL="qwen3.6-plus"
# Optional: retry when primary model fails (e.g. HTTP 402 upstream).
OPENAI_COMPAT_FALLBACK_MODEL="gemini/gemini-2.5-flash"
# Or use DeepSeek platform directly (not SumoPod key): OPENAI_COMPAT_BASE_URL="https://api.deepseek.com/v1"
OPENAI_COMPAT_TIMEOUT_MS="45000"
# Dashboard "Config" tab calls GET /api/runtime-config — returns which env vars are set, never secret values.

# Optional: sub-agent fleet (OpenAI-compat). See docs/OPENCLAW_INTEGRATION.md
FLEET_MAX_TOKENS_PER_SUB=""
FLEET_MERGE_MAX_TOKENS=""

# Optional: Lovable.dev API token — README squad menambahkan catatan integrasi bila di-set.
LOVABLE_API_KEY=""

# Tavily web-read step (legacy env name). Set BROWSER_AUTOMATION=0 to skip URL extract.
BROWSER_AUTOMATION=""
BROWSER_DEFAULT_URL=""
